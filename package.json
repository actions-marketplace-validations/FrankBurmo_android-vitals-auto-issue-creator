{
  "name": "android-vitals-issues",
  "version": "1.0.0",
  "private": true,
  "description": "Sync crash and ANR errors from Google Play Console to GitHub Issues",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "vitest run",
