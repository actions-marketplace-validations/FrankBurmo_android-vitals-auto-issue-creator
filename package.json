    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^10.4.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
